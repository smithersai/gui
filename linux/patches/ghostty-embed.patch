diff --git a/src/apprt/gtk/embed.zig b/src/apprt/gtk/embed.zig
new file mode 100644
index 000000000..589ff8d57
--- /dev/null
+++ b/src/apprt/gtk/embed.zig
@@ -0,0 +1,113 @@
+//! C ABI for embedding Ghostty's real GTK surface widget in a host GTK app.
+
+const std = @import("std");
+const gtk = @import("gtk");
+
+const CoreApp = @import("../../App.zig");
+const ApprtApp = @import("App.zig");
+const Application = @import("class/application.zig").Application;
+const Config = @import("class/config.zig").Config;
+const Surface = @import("class/surface.zig").Surface;
+const input = @import("../../input.zig");
+
+const log = std.log.scoped(.gtk_embed);
+
+pub const std_options: std.Options = .{};
+
+const EmbedApp = struct {
+    core_app: *CoreApp,
+    rt_app: *ApprtApp,
+};
+
+pub export fn ghostty_gtk_app_new() ?*EmbedApp {
+    return appNew() catch |err| {
+        log.err("error initializing embedded GTK app err={}", .{err});
+        return null;
+    };
+}
+
+fn appNew() !*EmbedApp {
+    const alloc = std.heap.c_allocator;
+
+    const core_app = try CoreApp.create(alloc);
+    errdefer core_app.destroy();
+
+    const rt_app = try alloc.create(ApprtApp);
+    errdefer alloc.destroy(rt_app);
+    try rt_app.init(core_app, .{});
+    errdefer rt_app.terminate();
+
+    Application.setEmbeddedDefault(rt_app.app);
+
+    const app = try alloc.create(EmbedApp);
+    app.* = .{
+        .core_app = core_app,
+        .rt_app = rt_app,
+    };
+    return app;
+}
+
+pub export fn ghostty_gtk_app_free(app: *EmbedApp) void {
+    const alloc = std.heap.c_allocator;
+    Application.setEmbeddedDefault(null);
+    app.rt_app.terminate();
+    app.rt_app.app.unref();
+    alloc.destroy(app.rt_app);
+    app.core_app.destroy();
+    alloc.destroy(app);
+}
+
+pub export fn ghostty_gtk_app_tick(app: *EmbedApp) void {
+    app.core_app.tick(app.rt_app) catch |err| {
+        log.err("error ticking embedded GTK app err={}", .{err});
+    };
+}
+
+pub export fn ghostty_gtk_surface_new(app: *EmbedApp) ?*Surface {
+    const config: *Config = app.rt_app.app.getConfig();
+    defer config.unref();
+
+    const surface = Surface.newWithCoreApp(app.core_app, config);
+    _ = surface.refSink();
+    return surface;
+}
+
+pub export fn ghostty_gtk_surface_widget(surface: *Surface) *gtk.Widget {
+    return surface.as(gtk.Widget);
+}
+
+pub export fn ghostty_gtk_surface_free(surface: *Surface) void {
+    surface.unref();
+}
+
+pub export fn ghostty_gtk_surface_redraw(surface: *Surface) void {
+    surface.redraw();
+}
+
+pub export fn ghostty_gtk_surface_title(surface: *Surface) ?[*:0]const u8 {
+    const title = surface.getEffectiveTitle() orelse return null;
+    return title.ptr;
+}
+
+pub export fn ghostty_gtk_surface_binding_action(
+    surface: *Surface,
+    action_ptr: [*]const u8,
+    action_len: usize,
+) bool {
+    const core_surface = surface.core() orelse return false;
+    const action_str = action_ptr[0..action_len];
+    const action = input.Binding.Action.parse(action_str) catch |err| {
+        log.err("error parsing binding action action={s} err={}", .{ action_str, err });
+        return false;
+    };
+
+    return core_surface.performBindingAction(action) catch |err| {
+        log.err("error performing binding action action={f} err={}", .{ action, err });
+        return false;
+    };
+}
+
+test {
+    _ = ghostty_gtk_app_new;
+    _ = ghostty_gtk_app_free;
+    _ = ghostty_gtk_app_tick;
+    _ = ghostty_gtk_surface_new;
+    _ = ghostty_gtk_surface_widget;
+    _ = ghostty_gtk_surface_free;
+    _ = ghostty_gtk_surface_redraw;
+    _ = ghostty_gtk_surface_title;
+    _ = ghostty_gtk_surface_binding_action;
+}
diff --git a/src/build/GhosttyLibGtk.zig b/src/build/GhosttyLibGtk.zig
new file mode 100644
index 000000000..c5b91a96f
--- /dev/null
+++ b/src/build/GhosttyLibGtk.zig
@@ -0,0 +1,40 @@
+const GhosttyLibGtk = @This();
+
+const std = @import("std");
+const Config = @import("Config.zig");
+const SharedDeps = @import("SharedDeps.zig");
+
+lib: *std.Build.Step.Compile,
+install_step: *std.Build.Step.InstallArtifact,
+
+pub fn initShared(
+    b: *std.Build,
+    cfg: *const Config,
+    deps: *const SharedDeps,
+) !GhosttyLibGtk {
+    const lib = b.addLibrary(.{
+        .name = "ghostty-gtk",
+        .linkage = .dynamic,
+        .root_module = b.createModule(.{
+            .root_source_file = b.path("src/apprt/gtk/embed.zig"),
+            .target = cfg.target,
+            .optimize = cfg.optimize,
+            .strip = cfg.strip,
+            .omit_frame_pointer = cfg.strip,
+            .unwind_tables = if (cfg.strip) .none else .sync,
+        }),
+        .use_llvm = true,
+    });
+
+    _ = try deps.add(lib);
+
+    return .{
+        .lib = lib,
+        .install_step = b.addInstallArtifact(lib, .{}),
+    };
+}
+
+pub fn install(self: *const GhosttyLibGtk) void {
+    const b = self.install_step.step.owner;
+    b.getInstallStep().dependOn(&self.install_step.step);
+}
